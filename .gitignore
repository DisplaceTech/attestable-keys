# Safety net: private key material must never exist in this repo, let alone
# be committed. Only the *.pub file is ever supposed to land here.
*.key
*.key.age

# `ots upgrade` writes one of these automatically before rewriting the
# proof in place; it's just the pre-upgrade backup, not a published artifact.
*.ots.bak

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
